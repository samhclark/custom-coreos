#!/bin/bash
# ABOUTME: Runs the Garage CLI inside the rootless Garage container.

set -euo pipefail

SERVICE_USER="_nas_garage"
SERVICE_UID="51110"
SERVICE_HOME="/var/home/${SERVICE_USER}"
RUNTIME_DIR="/run/user/${SERVICE_UID}"

podman_args=(exec -i)
if [[ -t 1 ]]; then
    podman_args+=(-t)
fi
podman_args+=(garage /garage)

cd /

if [[ "$(id -u)" == "${SERVICE_UID}" ]]; then
    export HOME="${SERVICE_HOME}"
    export XDG_RUNTIME_DIR="${RUNTIME_DIR}"
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${RUNTIME_DIR}/bus"
    exec podman "${podman_args[@]}" "$@"
fi

exec sudo -u "${SERVICE_USER}" env \
    HOME="${SERVICE_HOME}" \
    XDG_RUNTIME_DIR="${RUNTIME_DIR}" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=${RUNTIME_DIR}/bus" \
    podman "${podman_args[@]}" "$@"
