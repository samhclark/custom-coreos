#!/bin/bash
# ABOUTME: Convenience wrapper for managing podman secrets on the NAS.
# Provides simple commands for common secret operations.

set -euo pipefail

LOOKUP="/usr/local/lib/podman-secret-driver/lookup.sh"

usage() {
    cat <<'USAGE'
Usage: nas-secrets <command> [args]

Commands:
  list                  List all secrets
  show <name>           Show a secret's decrypted value
  create <name>         Create a secret (reads value from stdin)
  create <name> <file>  Create a secret from a file
  delete <name>         Delete a secret
  rotate <name>         Rotate a secret (reads new value from stdin)
  help                  Show this help

Examples:
  echo 'my-token' | nas-secrets create my-secret
  nas-secrets show my-secret
  nas-secrets list
  echo 'new-value' | nas-secrets rotate my-secret
USAGE
}

case "${1:-help}" in
    list)
        podman secret ls
        ;;
    show)
        [[ -z "${2:-}" ]] && { echo "Usage: nas-secrets show <name>" >&2; exit 1; }
        SECRET_ID="$2" "$LOOKUP"
        ;;
    create)
        [[ -z "${2:-}" ]] && { echo "Usage: nas-secrets create <name> [file]" >&2; exit 1; }
        if [[ -n "${3:-}" ]]; then
            podman secret create "$2" "$3"
        else
            podman secret create "$2" -
        fi
        ;;
    delete)
        [[ -z "${2:-}" ]] && { echo "Usage: nas-secrets delete <name>" >&2; exit 1; }
        podman secret rm "$2"
        ;;
    rotate)
        [[ -z "${2:-}" ]] && { echo "Usage: nas-secrets rotate <name>" >&2; exit 1; }
        podman secret rm "$2"
        podman secret create "$2" -
        echo "Secret '$2' rotated. Restart affected containers to pick up the new value."
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
