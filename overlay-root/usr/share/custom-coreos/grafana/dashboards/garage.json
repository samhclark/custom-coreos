{
  "uid": "garage",
  "id": null,
  "title": "Garage S3 Storage",
  "description": "Garage S3-compatible object storage metrics. Availability uses a fast /health probe via blackbox exporter. Internal Garage metrics panels use the last successful /metrics sample over 15m because that endpoint can respond slowly even when the service is healthy.",
  "tags": ["garage", "s3", "storage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "title": "Cluster Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Cluster Healthy",
      "description": "Cluster health from the last successful metrics sample in the past 15 minutes",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" }, "0": { "text": "UNHEALTHY", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "last_over_time(cluster_healthy{job=\"garage\"}[15m])",
          "legendFormat": "Healthy",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Health Endpoint",
      "description": "Fast /health probe via blackbox exporter. This is the authoritative Garage availability signal.",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "last_over_time(probe_success{job=\"garage-health\",service=\"garage\"}[5m]) or on() vector(0)",
          "legendFormat": "Health",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Garage Disk Available",
      "description": "Available disk space from the last successful metrics sample in the past 15 minutes",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 10737418240, "color": "yellow" },
              { "value": 107374182400, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "last_over_time(garage_local_disk_avail{job=\"garage\"}[15m])",
          "legendFormat": "{{volume}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Garage Build Info",
      "description": "Garage version from the last successful metrics sample in the past 15 minutes",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "name",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "max_over_time(garage_build_info{job=\"garage\"}[15m])",
          "legendFormat": "{{version}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 API",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "S3 Request Rate",
      "description": "S3 API requests per second by endpoint, smoothed over 15 minutes to tolerate slow metrics scrapes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal" },
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
      "expr": "rate(api_s3_request_counter{job=\"garage\"}[15m])",
          "legendFormat": "{{api_endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Error Rate",
      "description": "S3 API errors per second by endpoint, smoothed over 15 minutes to tolerate slow metrics scrapes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
      "expr": "rate(api_s3_error_counter{job=\"garage\"}[15m])",
          "legendFormat": "{{api_endpoint}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Request Duration (p50 / p95 / p99)",
      "description": "S3 API call latency percentiles, smoothed over 15 minutes to tolerate slow metrics scrapes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
      "expr": "histogram_quantile(0.50, rate(api_s3_request_duration_bucket{job=\"garage\"}[15m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
      "expr": "histogram_quantile(0.95, rate(api_s3_request_duration_bucket{job=\"garage\"}[15m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
      "expr": "histogram_quantile(0.99, rate(api_s3_request_duration_bucket{job=\"garage\"}[15m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Block Storage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Block I/O Throughput",
      "description": "Bytes read/written to data directory, smoothed over 15 minutes to tolerate slow metrics scrapes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Written" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
      "expr": "rate(block_bytes_read{job=\"garage\"}[15m])",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
      "expr": "rate(block_bytes_written{job=\"garage\"}[15m])",
          "legendFormat": "Written",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Block Resync Queue",
      "description": "Blocks queued for resync from the last successful metrics sample in the past 15 minutes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
      "expr": "last_over_time(block_resync_queue_length{job=\"garage\"}[15m])",
          "legendFormat": "Queue Length",
          "refId": "A"
        },
        {
      "expr": "last_over_time(block_resync_errored_blocks{job=\"garage\"}[15m])",
          "legendFormat": "Errored Blocks",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Metadata",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "Merkle Updater Queue",
      "description": "Merkle tree updater TODO queue per table from the last successful metrics sample in the past 15 minutes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
      "expr": "last_over_time(table_merkle_updater_todo_queue_length{job=\"garage\"}[15m])",
          "legendFormat": "{{table_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Table GC Queue",
      "description": "Garbage collection TODO queue length per table from the last successful metrics sample in the past 15 minutes",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
      "expr": "last_over_time(table_gc_todo_queue_length{job=\"garage\"}[15m])",
          "legendFormat": "{{table_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
