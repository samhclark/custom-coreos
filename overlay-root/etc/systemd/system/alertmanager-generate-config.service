[Unit]
Description=Generate Alertmanager config from template with Pushover secrets
After=age-tpm-identity.service
Requires=age-tpm-identity.service
Before=alertmanager.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/alertmanager-generate-config.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
