{
  "uid": "alertmanager",
  "id": null,
  "title": "Alertmanager",
  "description": "Alertmanager notification pipeline and alert status",
  "tags": ["alertmanager", "alerting"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "title": "Alert Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Active Alerts",
      "description": "Number of currently active alerts by state",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "alertmanager_alerts{job=\"alertmanager\", state=\"active\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Suppressed Alerts",
      "description": "Alerts currently suppressed (silenced or inhibited)",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "alertmanager_alerts{job=\"alertmanager\", state=\"suppressed\"}",
          "legendFormat": "Suppressed",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alertmanager Up",
      "description": "Whether Alertmanager is being successfully scraped",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "up{job=\"alertmanager\"}",
          "legendFormat": "Alertmanager",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alerts Over Time",
      "description": "Active and suppressed alerts over time",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "alertmanager_alerts{job=\"alertmanager\", state=\"active\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "alertmanager_alerts{job=\"alertmanager\", state=\"suppressed\"}",
          "legendFormat": "Suppressed",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Notifications",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "Notification Rate",
      "description": "Notifications sent per second by integration",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "rate(alertmanager_notifications_total{job=\"alertmanager\"}[5m])",
          "legendFormat": "{{integration}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Notification Failures",
      "description": "Failed notifications per second by integration",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "rate(alertmanager_notifications_failed_total{job=\"alertmanager\"}[5m])",
          "legendFormat": "{{integration}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Notification Latency (p50 / p95 / p99)",
      "description": "Time to send notifications by integration",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(alertmanager_notification_latency_seconds_bucket{job=\"alertmanager\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(alertmanager_notification_latency_seconds_bucket{job=\"alertmanager\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(alertmanager_notification_latency_seconds_bucket{job=\"alertmanager\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "vmalert Rules",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "title": "Alerts Firing (vmalert)",
      "description": "Number of alerts currently firing in vmalert",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alerts Pending (vmalert)",
      "description": "Alerts in pending state (within for duration)",
      "type": "stat",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"pending\"}) or vector(0)",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rule Evaluation Errors",
      "description": "vmalert rule evaluation errors over time",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-metrics-datasource", "uid": "" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(vmalert_alerting_rules_errors_total{job=\"vmalert\"}[5m])",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    }
  ]
}
